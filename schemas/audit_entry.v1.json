{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Fratres-X-AI/fratres-sentry/schemas/audit_entry.v1.json",
  "title": "SENTRY audit_entry.v1",
  "type": "object",
  "required": ["schema", "seq", "timestamp_s", "event", "payload_hash", "prev_hash", "entry_hash", "entry_integrity_hash"],
  "properties": {
    "schema": { "const": "audit_entry.v1" },
    "codename": { "const": "SENTRY" },
    "seq": { "type": "integer", "minimum": 0 },
    "timestamp_s": { "type": "number", "minimum": 0 },
    "event": { "type": "string", "minLength": 1 },
    "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "prev_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "entry_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "entry_integrity_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
